{
  "name": "agent-library",
  "version": "0.1.0",
  "type": "module",
  "bin": { "agent-library": "./bin/agent-library" },
  "scripts": {
    "build": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile bin/agent-library",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  }
}
